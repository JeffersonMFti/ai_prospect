# ===== .env.example (raiz) =====
# Copie os blocos relevantes para agent/.env, web/.env e os secrets do Supabase.
# NUNCA commite o .env real. Veja specs/orchestration/interface-contracts.md (C6).

# ---- Agente local (agent/.env) ----
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
GEMINI_API_KEY=                 # opcional: expandir queries / limpar leads
POLL_INTERVAL_SECONDS=5

# ---- Supabase (supabase secrets set ...) ----
# GEMINI_API_KEY=
# UAZAPI_BASE_URL=              # ex.: https://sua-instancia.uazapi.com
# UAZAPI_TOKEN=
# PROJECT_URL=                  # URL do projeto (p/ pg_cron invocar Edge Functions)
# SERVICE_ROLE_KEY=            # service role (p/ pg_cron)

# ---- Dashboard web (web/.env) ----
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
