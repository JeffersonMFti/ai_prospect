# =============================================================================
#  ai_prospect — TODAS as chaves do projeto (referência mestre)
# =============================================================================
#  Este arquivo lista TUDO que você precisa preencher. Ele se divide em 3 destinos:
#    • agent/.env        → o agente local (scraper) na sua máquina
#    • web/.env          → o dashboard (só chaves PÚBLICAS)
#    • Supabase secrets  → as Edge Functions (via `supabase secrets set ...`)
#
#  ⚠️ NUNCA commite os .env reais (já estão no .gitignore).
#  ⚠️ NUNCA cole as chaves marcadas 🔒 SECRETO em chat/lugar público.
#
#  Onde pegar cada valor:
#    Supabase  → https://supabase.com/dashboard/project/YOUR_PROJECT_REF/settings/api
#    Gemini    → https://aistudio.google.com/apikey
#    uazapi    → painel da sua instância (Base URL + Token)
# =============================================================================


# ─────────────────────────────────────────────────────────────────────────────
#  BLOCO 1 → copie para  agent/.env   (roda o scraper na sua máquina)
# ─────────────────────────────────────────────────────────────────────────────
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=          # 🔒 SECRETO — "service_role" em Settings → API
GEMINI_API_KEY=                     # 🔒 opcional (expandir queries/limpar leads)
POLL_INTERVAL_SECONDS=5
HEADLESS=false                      # navegador real (decisão do projeto)
MIN_DELAY_MS=2000
MAX_DELAY_MS=6000


# ─────────────────────────────────────────────────────────────────────────────
#  BLOCO 2 → copie para  web/.env    (dashboard — só chaves públicas)
# ─────────────────────────────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=             # "anon" / "publishable" em Settings → API (público, ok)


# ─────────────────────────────────────────────────────────────────────────────
#  BLOCO 3 → vira SECRET das Edge Functions (NÃO é arquivo):
#    supabase secrets set GEMINI_API_KEY=... UAZAPI_BASE_URL=... UAZAPI_TOKEN=...
#  (SUPABASE_URL e SUPABASE_SERVICE_ROLE_KEY já são injetados automaticamente
#   nas Edge Functions pelo Supabase — não precisa setar manualmente.)
# ─────────────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=                     # 🔒 SECRETO — Google AI Studio
UAZAPI_BASE_URL=                    # ex.: https://sua-instancia.uazapi.com
UAZAPI_TOKEN=                       # 🔒 SECRETO — token da instância de WhatsApp


# ─────────────────────────────────────────────────────────────────────────────
#  BLOCO 4 → SECRETS DO VAULT (rodar 1x no SQL Editor, p/ o pg_cron chamar as EFs)
#    select vault.create_secret('https://YOUR_PROJECT_REF.supabase.co', 'project_url');
#    select vault.create_secret('<SERVICE_ROLE_KEY>', 'service_role_key');
#  Depois rode a migration supabase/migrations/0002_cron.sql para reativar o cron.
# ─────────────────────────────────────────────────────────────────────────────
# (sem variáveis aqui — é SQL; veja DEPLOY.md passo 5)
